LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
LLM_MODEL=claude-sonnet-4-20250514
LLM_TIMEOUT_MS=8000
